---
// src/pages/sutras/[id].astro — Museum-quality parallel reader
import Base from '../../layouts/Base.astro';
import { getTextById, getSegmentsByText, getTextsByWork } from '../../lib/db';

const { id } = Astro.params;
const textId = Number(id);
const text = getTextById(textId);

if (!text) return Astro.redirect('/texts');

const allSegments = getSegmentsByText(textId);
const segments = allSegments.filter(s => s.th);
const totalSegments = allSegments.length;
const pctTranslated = totalSegments
  ? Math.round((segments.length / totalSegments) * 100)
  : 0;

const juanSiblings = text.cbeta_id ? getTextsByWork(text.cbeta_id) : [];
const juanIdx = juanSiblings.findIndex(j => j.id === textId);
const prevJuan = juanSiblings[juanIdx - 1] ?? null;
const nextJuan = juanSiblings[juanIdx + 1] ?? null;
const hasMultipleJuan = juanSiblings.length > 1;

function isVerseSegment(seg: { zh: string }): boolean {
  return seg.zh.includes('\n') || /^[　\s]/.test(seg.zh);
}
---

<Base title={`${text.title} — 佛典譯場`}>
  <article class="sutra-container">

    <!-- Masthead -->
    <header class="sutra-masthead">
      <div class="masthead-ornament" aria-hidden="true">❦</div>

      <h1 class="sutra-title">{text.title}</h1>

      <div class="sutra-meta">
        {text.cbeta_id && <span class="meta-cbeta">{text.cbeta_id}</span>}
        {text.cbeta_id && hasMultipleJuan && <span class="meta-divider" aria-hidden="true">/</span>}
        {hasMultipleJuan && (
          <span class="meta-juan" lang="zh-Hant">
            卷{text.juan}{text.total_juans ? `之${text.total_juans}` : ''}
          </span>
        )}
      </div>

      {pctTranslated < 100 && (
        <div class="translation-progress" role="status">
          <div class="progress-bar">
            <div class="progress-fill" style={`width: ${pctTranslated}%`}></div>
          </div>
          <span class="progress-label">แปลแล้ว {pctTranslated}%</span>
        </div>
      )}

      {hasMultipleJuan && (
        <nav class="juan-nav" aria-label="Fascicle navigation">
          {prevJuan ? (
            <a href={`/sutras/${prevJuan.id}`} class="juan-link juan-prev">
              <span class="juan-arrow" aria-hidden="true">‹</span>
              <span class="juan-label" lang="zh-Hant">卷{prevJuan.juan}</span>
            </a>
          ) : (
            <span class="juan-link juan-disabled"><span class="juan-arrow">‹</span></span>
          )}

          <div class="juan-dots">
            {juanSiblings.map((j) => (
              <a
                href={`/sutras/${j.id}`}
                class={`juan-dot ${j.id === textId ? 'juan-dot-active' : ''}`}
                aria-label={`卷${j.juan}`}
                aria-current={j.id === textId ? 'page' : undefined}
                title={`卷${j.juan}`}
              >
                <span class="juan-dot-inner" />
              </a>
            ))}
          </div>

          {nextJuan ? (
            <a href={`/sutras/${nextJuan.id}`} class="juan-link juan-next">
              <span class="juan-label" lang="zh-Hant">卷{nextJuan.juan}</span>
              <span class="juan-arrow" aria-hidden="true">›</span>
            </a>
          ) : (
            <span class="juan-link juan-disabled"><span class="juan-arrow">›</span></span>
          )}
        </nav>
      )}

      <div class="sutra-actions">
        <a href={`/texts/${textId}`} class="action-link">
          <span class="action-icon">✎</span><span>แก้ไข</span>
        </a>
        <a href={`/api/export/${textId}`} class="action-link" download>
          <span class="action-icon">↓</span><span>JSON</span>
        </a>
      </div>
    </header>

    <!-- Parallel Reader -->
    <div class="parallel-reader">
      <div class="column-headers" aria-hidden="true">
        <div class="col-header col-header-zh">
          <span class="col-label" lang="zh-Hant">原文</span>
          <span class="col-sublabel">Classical Chinese</span>
        </div>
        <div class="col-header col-header-th">
          <span class="col-label">คำแปล</span>
          <span class="col-sublabel">Thai</span>
        </div>
      </div>

      <div class="sutra-content">
        {segments.map((seg) => {
          const isVerse = isVerseSegment(seg);
          return (
            <section
              class={`parallel-row ${isVerse ? 'parallel-row-verse' : ''}`}
              id={`s${seg.seq}`}
            >
              <div class="line-marker">
                <a href={`#s${seg.seq}`} class="line-anchor">{seg.seq}</a>
              </div>

              <div class="text-col col-chinese" lang="zh-Hant">
                <p class={`chinese-text ${isVerse ? 'verse' : 'prose'}`}>{seg.zh}</p>
              </div>

              <div class="text-col col-thai" lang="th">
                <p class={`thai-text ${isVerse ? 'verse' : 'prose'}`}>{seg.th}</p>
                {seg.notes && (
                  <aside class="scholar-note">
                    <span class="note-glyph" aria-hidden="true">※</span>
                    <span class="note-content">{seg.notes}</span>
                  </aside>
                )}
              </div>
            </section>
          );
        })}
      </div>
    </div>

    <!-- Colophon -->
    <footer class="sutra-colophon">
      <div class="colophon-rule" aria-hidden="true">
        <span class="rule-ornament">❦</span>
      </div>
      <p class="colophon-text">
        แปลจากพระไตรปิฎกจีน <span class="colophon-sep">·</span>
        漢文大藏經 <span class="colophon-sep">·</span>
        {text.cbeta_id || 'Unknown source'}
      </p>
      <p class="colophon-sub">สำนักแปลพระไตรปิฎกจีนสู่ภาษาไทย · 佛典譯場</p>
    </footer>

  </article>
</Base>

<style>
/* ── Container ── */
.sutra-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 3rem 2rem 6rem;
}

/* ── Masthead ── */
.sutra-masthead {
  text-align: center;
  padding-bottom: 3rem;
  margin-bottom: 2rem;
  border-bottom: 1px solid var(--border-soft);
}

.masthead-ornament {
  font-size: 1.4rem;
  color: var(--gold);
  letter-spacing: 0.3em;
  margin-bottom: 1.5rem;
  opacity: 0.55;
}

.sutra-title {
  font-family: var(--font-zh);
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 400;
  color: var(--ink);
  letter-spacing: 0.15em;
  line-height: 1.4;
  margin: 0 0 1rem;
}

.sutra-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.6rem;
  font-size: 0.875rem;
  color: var(--ink-light);
  margin-bottom: 1.5rem;
}

.meta-cbeta {
  font-family: var(--font-ui);
  font-weight: 500;
  color: var(--gold);
  background: var(--gold-pale);
  padding: 0.15rem 0.55rem;
  border-radius: 3px;
  border: 1px solid var(--gold-dim);
  font-size: 0.78rem;
}

.meta-juan {
  font-family: var(--font-zh);
  color: var(--ink-light);
  letter-spacing: 0.1em;
}

.meta-divider { color: var(--border); }

/* ── Progress ── */
.translation-progress {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.progress-bar {
  width: 100px;
  height: 2px;
  background: var(--border-soft);
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--gold-dim), var(--gold));
}

.progress-label {
  font-size: 0.72rem;
  color: var(--ink-light);
  letter-spacing: 0.03em;
}

/* ── Juan Nav ── */
.juan-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.25rem;
  margin-bottom: 1.5rem;
}

.juan-link {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  text-decoration: none;
  color: var(--ink-light);
  font-size: 0.85rem;
  padding: 0.35rem 0.75rem;
  border-radius: 4px;
  transition: all 0.15s;
}
.juan-link:hover { color: var(--gold); background: var(--gold-pale); }
.juan-disabled { opacity: 0.25; cursor: default; pointer-events: none; }

.juan-arrow { font-size: 1.2rem; color: var(--gold); line-height: 1; }
.juan-label { font-family: var(--font-zh); letter-spacing: 0.08em; }

.juan-dots { display: flex; gap: 0.35rem; }

.juan-dot {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  transition: all 0.15s;
}
.juan-dot:hover { border-color: var(--gold); transform: scale(1.15); }
.juan-dot-active { background: var(--gold); border-color: var(--gold); }
.juan-dot-inner { width: 3px; height: 3px; border-radius: 50%; background: white; opacity: 0; }
.juan-dot-active .juan-dot-inner { opacity: 1; }

/* ── Actions ── */
.sutra-actions {
  display: flex;
  justify-content: center;
  gap: 1.25rem;
}

.action-link {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  color: var(--ink-light);
  text-decoration: none;
  font-size: 0.78rem;
  padding: 0.25rem 0.6rem;
  border-radius: 3px;
  opacity: 0.6;
  transition: all 0.15s;
}
.action-link:hover { opacity: 1; color: var(--gold); background: var(--gold-pale); }
.action-icon { font-size: 0.85rem; }

/* ── Column Headers ── */
.column-headers {
  display: grid;
  grid-template-columns: 3rem 1fr 1fr;
  border-bottom: 2px solid var(--border);
  margin-bottom: 0;
}

.col-header {
  padding: 0.85rem 1.5rem 0.7rem;
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.col-header-zh {
  grid-column: 2;
  border-right: 1px solid var(--border-soft);
}

.col-label {
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ink);
}

.col-header-zh .col-label { font-family: var(--font-zh); }

.col-sublabel {
  font-family: var(--font-en);
  font-size: 0.62rem;
  color: var(--border);
  letter-spacing: 0.08em;
}

/* ── Rows ── */
.sutra-content {
  border-left: 1px solid var(--border-soft);
  border-right: 1px solid var(--border-soft);
  border-bottom: 1px solid var(--border-soft);
  border-radius: 0 0 4px 4px;
}

.parallel-row {
  display: grid;
  grid-template-columns: 3rem 1fr 1fr;
  border-bottom: 1px solid var(--border-soft);
  transition: background 0.12s;
}
.parallel-row:last-child { border-bottom: none; }
.parallel-row:hover { background: rgba(184,148,63,0.025); }
.parallel-row-verse { background: rgba(184,148,63,0.018); }
.parallel-row-verse:hover { background: rgba(184,148,63,0.04); }

/* ── Line Number ── */
.line-marker {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 1.3rem;
  border-right: 1px solid var(--border-soft);
}

.line-anchor {
  font-family: 'SF Mono', 'Fira Code', monospace;
  font-size: 0.6rem;
  color: var(--border);
  text-decoration: none;
  transition: color 0.15s;
  padding: 0.2rem;
  min-width: 1.4rem;
  text-align: center;
}
.line-anchor:hover { color: var(--gold); }

/* ── Text Columns ── */
.text-col { padding: 1.25rem 1.5rem; }
.col-chinese { border-right: 1px solid var(--border-soft); }

/* ── Chinese Typography ── */
.chinese-text {
  font-family: var(--font-zh);
  font-size: 1.1rem;
  font-weight: 400;
  line-height: 2.2;
  color: var(--zh-col);
  white-space: pre-wrap;
  margin: 0;
  letter-spacing: 0.05em;
}
.chinese-text.prose { text-align: justify; text-justify: inter-ideograph; }
.chinese-text.verse {
  font-size: 1rem;
  line-height: 2.6;
  letter-spacing: 0.08em;
  color: #3d2614;
  padding-left: 1rem;
  position: relative;
}
.chinese-text.verse::before {
  content: '';
  position: absolute;
  left: 0; top: 0.3rem; bottom: 0.3rem;
  width: 3px;
  background: linear-gradient(180deg, var(--gold-dim), var(--gold));
  border-radius: 2px;
  opacity: 0.5;
}

/* ── Thai Typography ── */
.thai-text {
  font-family: var(--font-th);
  font-size: 1.05rem;
  font-weight: 400;
  line-height: 2.4;
  color: var(--th-col);
  white-space: pre-wrap;
  margin: 0;
}
.thai-text.prose { text-align: justify; hyphens: auto; }
.thai-text.verse {
  font-size: 1rem;
  line-height: 2.8;
  color: #1a3d2e;
  padding-left: 1rem;
  position: relative;
}
.thai-text.verse::before {
  content: '';
  position: absolute;
  left: 0; top: 0.4rem; bottom: 0.4rem;
  width: 3px;
  background: linear-gradient(180deg, #5a8a6a, #2a6b4a);
  border-radius: 2px;
  opacity: 0.45;
}

/* ── Scholar Notes ── */
.scholar-note {
  margin-top: 0.85rem;
  padding: 0.65rem 0.9rem;
  background: linear-gradient(135deg, #fffdf5, #fdf9ed);
  border-left: 2px solid var(--gold-dim);
  border-radius: 0 4px 4px 0;
  font-family: var(--font-ui);
  font-size: 0.78rem;
  line-height: 1.7;
  color: var(--ink-light);
  display: flex;
  gap: 0.55rem;
  align-items: flex-start;
}

.note-glyph {
  font-family: var(--font-zh);
  font-size: 0.85rem;
  color: var(--gold);
  flex-shrink: 0;
  margin-top: 0.05rem;
}

/* ── Colophon ── */
.sutra-colophon {
  margin-top: 5rem;
  padding-top: 3rem;
  text-align: center;
  border-top: 1px solid var(--border-soft);
}

.colophon-rule {
  position: relative;
  margin-bottom: 2rem;
}
.colophon-rule::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 20%; right: 20%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border), transparent);
}
.rule-ornament {
  position: relative;
  background: var(--cream);
  padding: 0 1rem;
  font-size: 1.1rem;
  color: var(--gold);
  opacity: 0.5;
}

.colophon-text {
  font-family: var(--font-en);
  font-size: 0.82rem;
  color: var(--ink-light);
  letter-spacing: 0.06em;
  margin-bottom: 0.4rem;
}
.colophon-sep { color: var(--border); margin: 0 0.4rem; }
.colophon-sub {
  font-size: 0.72rem;
  color: var(--border);
  letter-spacing: 0.08em;
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .sutra-container { padding: 2rem 1.25rem 4rem; }
  .text-col { padding: 1rem 1.1rem; }
  .chinese-text { font-size: 1rem; line-height: 2; }
  .thai-text { font-size: 0.95rem; line-height: 2.2; }
}

@media (max-width: 640px) {
  .sutra-container { padding: 1.5rem 1rem 3rem; }
  .column-headers { display: none; }
  .parallel-row { display: block; padding: 1.25rem 0; }
  .line-marker { display: none; }
  .col-chinese {
    border-right: none;
    border-bottom: 1px dashed var(--border-soft);
    padding-bottom: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .col-chinese::before {
    content: '原文';
    font-family: var(--font-zh);
    font-size: 0.62rem;
    color: var(--gold);
    opacity: 0.65;
    display: block;
    margin-bottom: 0.4rem;
    letter-spacing: 0.12em;
  }
  .col-thai::before {
    content: 'คำแปล';
    font-family: var(--font-ui);
    font-size: 0.62rem;
    color: var(--gold);
    opacity: 0.65;
    display: block;
    margin-bottom: 0.4rem;
    letter-spacing: 0.05em;
  }
  .juan-label { display: none; }
  .juan-dot { width: 8px; height: 8px; }
}

/* ── Print ── */
@media print {
  .sutra-container { max-width: none; padding: 0; }
  .masthead-ornament, .juan-nav, .sutra-actions,
  .translation-progress, .line-marker, .column-headers { display: none !important; }
  .sutra-masthead { border-bottom: 1.5pt solid #1a1410; }
  .sutra-title { font-size: 18pt; }
  .parallel-row { break-inside: avoid; border-bottom: 0.5pt solid #ddd; }
  .col-chinese { border-right: 0.5pt solid #ccc; }
  .chinese-text { font-size: 11pt; line-height: 1.9; }
  .thai-text { font-size: 10.5pt; line-height: 2; }
  .scholar-note { font-size: 9pt; background: #f8f8f8 !important; }
  .sutra-colophon { border-top: 1pt solid #ccc; }
  .colophon-text, .colophon-sub { color: #666; }
}
</style>
